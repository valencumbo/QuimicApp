rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false; 
    }

    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return false; /* No admin roles defined */ }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Validation definitions
    function isTimestamp(val) { return val is timestamp; }
    function isTimeNow(val) { return isTimestamp(val) && val == request.time; }
    function isPositiveNumber(val) { return val is number && val >= 0; }
    function isShortString(val) { return val is string && val.size() <= 200; }
    function isValidProductType(val) { return val is string && val in ['resale', 'raw', 'processed']; }

    // Entities Validations
    function isValidWorkspace(data) {
      return data.keys().hasAll(['ownerId', 'settings', 'createdAt', 'updatedAt'])
        && data.keys().size() == 4
        && data.ownerId == request.auth.uid
        && data.settings is map
        && data.settings.keys().hasAll(['currency', 'defaultMargin', 'lowStockLimit'])
        && data.settings.keys().size() <= 5
        && isShortString(data.settings.currency)
        && isPositiveNumber(data.settings.defaultMargin)
        && isPositiveNumber(data.settings.lowStockLimit)
        && (data.settings.get('usdRate', 1) is number && data.settings.get('usdRate', 1) >= 0)
        && (data.settings.get('usdRateHistory', []) is list);
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['workspaceId', 'name', 'type', 'unit', 'createdAt', 'updatedAt'])
        && data.workspaceId == request.auth.uid
        && isShortString(data.name)
        && isValidProductType(data.type)
        && isShortString(data.unit)
        && (data.get('sku', '') is string && data.get('sku', '').size() <= 100)
        && (data.get('currency', '') is string && data.get('currency', '').size() <= 10)
        && (data.get('supplier', '') is string && data.get('supplier', '').size() <= 200)
        && (data.get('category', '') is string && data.get('category', '').size() <= 100)
        && (data.get('stock', 0) is number && data.get('stock', 0) >= 0)
        && (data.get('purchaseCost', 0) is number && data.get('purchaseCost', 0) >= 0)
        && (data.get('extraCost', 0) is number && data.get('extraCost', 0) >= 0)
        && (data.get('wasteRate', 0) is number && data.get('wasteRate', 0) >= 0 && data.get('wasteRate', 0) <= 100)
        && (data.get('targetMargin', 0) is number && data.get('targetMargin', 0) >= 0)
        && (data.get('salePrice', 0) is number && data.get('salePrice', 0) >= 0);
    }

    function isValidPurchase(data) {
      return data.keys().hasAll(['workspaceId', 'productId', 'date', 'quantity', 'unitCost', 'createdAt'])
        && data.workspaceId == request.auth.uid
        && isShortString(data.productId)
        && isShortString(data.date)
        && isPositiveNumber(data.quantity)
        && isPositiveNumber(data.unitCost)
        && (data.get('supplier', '') is string && data.get('supplier', '').size() <= 200)
        && (data.get('extraCost', 0) is number && data.get('extraCost', 0) >= 0)
        && (data.get('note', '') is string && data.get('note', '').size() <= 1000);
    }

    function isValidRecipe(data) {
      return data.keys().hasAll(['workspaceId', 'productId', 'components', 'yield', 'processCost', 'createdAt', 'updatedAt'])
        && data.workspaceId == request.auth.uid
        && isShortString(data.productId)
        && data.components is list
        && data.components.size() > 0 
        && data.components.size() <= 50
        && (data.components[0] is map && data.components[0].keys().hasAll(['productId', 'quantity']) && data.components[0].productId is string && data.components[0].quantity is number)
        && isPositiveNumber(data.yield)
        && isPositiveNumber(data.processCost);
    }

    function isValidSupplier(data) {
      return data.keys().hasAll(['workspaceId', 'name', 'createdAt', 'updatedAt'])
        && data.workspaceId == request.auth.uid
        && isShortString(data.name)
        && (data.get('contact', '') is string && data.get('contact', '').size() <= 200)
        && (data.get('paymentTerms', '') is string && data.get('paymentTerms', '').size() <= 100)
        && (data.get('currency', '') is string && data.get('currency', '').size() <= 10)
        && (data.get('deliveryTime', 0) is number && data.get('deliveryTime', 0) >= 0)
        && (data.get('location', '') is string && data.get('location', '').size() <= 200)
        && (data.get('notes', '') is string && data.get('notes', '').size() <= 1000);
    }

    function isValidReminder(data) {
      return data.keys().hasAll(['workspaceId', 'title', 'dueDate', 'completed', 'createdAt', 'updatedAt'])
        && data.workspaceId == request.auth.uid
        && isShortString(data.title)
        && isShortString(data.dueDate)
        && data.completed is bool
        && (data.get('description', '') is string && data.get('description', '').size() <= 1000);
    }

    // Workspaces ----------------------------------------------------
    match /workspaces/{workspaceId} {
      // The Master Gate: user's workspace ID MUST be their UID
      function isOwner() {
        return isSignedIn() && workspaceId == request.auth.uid;
      }

      allow read: if isOwner();
      allow list: if isSignedIn() && workspaceId == request.auth.uid; // Effectively redundant for a single-doc path, but safe
      
      allow create: if isOwner()
                    && isValidId(workspaceId)
                    && isValidWorkspace(incoming())
                    && isTimeNow(incoming().createdAt)
                    && isTimeNow(incoming().updatedAt);
      
      allow update: if isOwner()
                    && isValidWorkspace(incoming())
                    && incoming().diff(existing()).affectedKeys().hasOnly(['settings', 'updatedAt'])
                    && isTimeNow(incoming().updatedAt)
                    && incoming().ownerId == existing().ownerId
                    && incoming().createdAt == existing().createdAt;
      
      allow delete: if false; // Deny deletion of workspaces

      // Sub-collection: Products ------------------------------------
      match /products/{productId} {
        allow read: if isOwner() && existing().workspaceId == request.auth.uid;
        allow list: if isOwner() && resource.data.workspaceId == request.auth.uid;

        allow create: if isOwner()
                      && isValidId(productId)
                      && isValidProduct(incoming())
                      && isTimeNow(incoming().createdAt)
                      && isTimeNow(incoming().updatedAt);

        allow update: if isOwner()
                      && isValidProduct(incoming())
                      && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'sku', 'type', 'unit', 'currency', 'supplier', 'category', 'stock', 'purchaseCost', 'extraCost', 'wasteRate', 'targetMargin', 'salePrice', 'updatedAt'])
                      && isTimeNow(incoming().updatedAt)
                      && incoming().workspaceId == existing().workspaceId
                      && incoming().createdAt == existing().createdAt;
                      
        allow delete: if isOwner() && existing().workspaceId == request.auth.uid;
      }

      // Sub-collection: Purchases -----------------------------------
      match /purchases/{purchaseId} {
        allow read: if isOwner() && existing().workspaceId == request.auth.uid;
        allow list: if isOwner() && resource.data.workspaceId == request.auth.uid;

        allow create: if isOwner()
                      && isValidId(purchaseId)
                      && isValidPurchase(incoming())
                      && isTimeNow(incoming().createdAt);

        allow update: if false; // Purchases are immutable logs of events

        allow delete: if isOwner() && existing().workspaceId == request.auth.uid;
      }

      // Sub-collection: Recipes -------------------------------------
      match /recipes/{recipeId} {
        allow read: if isOwner() && existing().workspaceId == request.auth.uid;
        allow list: if isOwner() && resource.data.workspaceId == request.auth.uid;

        allow create: if isOwner()
                      && isValidId(recipeId)
                      && isValidRecipe(incoming())
                      && isTimeNow(incoming().createdAt)
                      && isTimeNow(incoming().updatedAt);

        allow update: if isOwner()
                      && isValidRecipe(incoming())
                      && incoming().diff(existing()).affectedKeys().hasOnly(['productId', 'components', 'yield', 'processCost', 'updatedAt'])
                      && isTimeNow(incoming().updatedAt)
                      && incoming().workspaceId == existing().workspaceId
                      && incoming().createdAt == existing().createdAt;

        allow delete: if isOwner() && existing().workspaceId == request.auth.uid;
      }

      // Sub-collection: Suppliers -------------------------------------
      match /suppliers/{supplierId} {
        allow read: if isOwner() && existing().workspaceId == request.auth.uid;
        allow list: if isOwner() && resource.data.workspaceId == request.auth.uid;

        allow create: if isOwner()
                      && isValidId(supplierId)
                      && isValidSupplier(incoming())
                      && isTimeNow(incoming().createdAt)
                      && isTimeNow(incoming().updatedAt);

        allow update: if isOwner()
                      && isValidSupplier(incoming())
                      && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'contact', 'paymentTerms', 'currency', 'deliveryTime', 'location', 'notes', 'updatedAt'])
                      && isTimeNow(incoming().updatedAt)
                      && incoming().workspaceId == existing().workspaceId
                      && incoming().createdAt == existing().createdAt;

        allow delete: if isOwner() && existing().workspaceId == request.auth.uid;
      }

      // Sub-collection: Reminders -------------------------------------
      match /reminders/{reminderId} {
        allow read: if isOwner() && existing().workspaceId == request.auth.uid;
        allow list: if isOwner() && resource.data.workspaceId == request.auth.uid;

        allow create: if isOwner()
                      && isValidId(reminderId)
                      && isValidReminder(incoming())
                      && isTimeNow(incoming().createdAt)
                      && isTimeNow(incoming().updatedAt);

        allow update: if isOwner()
                      && isValidReminder(incoming())
                      && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'description', 'dueDate', 'completed', 'updatedAt'])
                      && isTimeNow(incoming().updatedAt)
                      && incoming().workspaceId == existing().workspaceId
                      && incoming().createdAt == existing().createdAt;

        allow delete: if isOwner() && existing().workspaceId == request.auth.uid;
      }
    }
  }
}
